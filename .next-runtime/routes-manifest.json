{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/projects/bike-powered-car-wash-mvp",
      "regex": "^/projects/bike\\-powered\\-car\\-wash\\-mvp(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/projects/bike\\-powered\\-car\\-wash\\-mvp(?:/)?$"
    },
    {
      "page": "/projects/grow-together",
      "regex": "^/projects/grow\\-together(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/projects/grow\\-together(?:/)?$"
    },
    {
      "page": "/projects/live-chat-system",
      "regex": "^/projects/live\\-chat\\-system(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/projects/live\\-chat\\-system(?:/)?$"
    },
    {
      "page": "/projects/nashmi-cx",
      "regex": "^/projects/nashmi\\-cx(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/projects/nashmi\\-cx(?:/)?$"
    },
    {
      "page": "/projects/talqa-operations",
      "regex": "^/projects/talqa\\-operations(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/projects/talqa\\-operations(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}